# Rename this file to .env and fill in your own values for local development.

SECRET_KEY=replace_with_real_secret
FIELD_ENCRYPTION_KEY=replace_with_real_key
BREVO_API_KEY=replace_with_real_brevo_api_key

DB_HOST=localhost
DB_USER=youruser
DB_PASSWORD=yourpassword
DB_NAME=diabeatit_db
DB_PORT=3306

PUSH_VAPID_PUBLIC_KEY=replace_with_public_key
PUSH_VAPID_PRIVATE_KEY=replace_with_private_key
PUSH_VAPID_CLAIMS_SUBJECT=mailto:admin@example.com

ENFORCE_HTTPS=false
TRUST_PROXY_HEADERS=false
CORS_ALLOWED_ORIGINS=*

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_admin_password
